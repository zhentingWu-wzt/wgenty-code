# Wgenty Code - Environment Variables
#
# Copy this file to .env and fill in your API keys.
# Or export these variables directly in your shell.
#
# Priority: ANTHROPIC_API_KEY > DASHSCOPE_API_KEY > DEEPSEEK_API_KEY

# Anthropic (Claude) - https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# DeepSeek - https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# DashScope (Alibaba Cloud) - https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Override the API base URL (optional)
# API_BASE_URL=https://api.anthropic.com

# Log level (optional): trace, debug, info, warn, error
# RUST_LOG=info
